<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Approved Requests</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="page-shell">
    <div class="card stack-lg">
      <div class="page-header">
        <h2 class="page-heading">Approved Certificate Requests</h2>
      </div>

      <% if (!requests.length) { %>
        <div class="message-box info-box empty">No approved or issued requests found.</div>
      <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Requester</th>
                <th>Common Name</th>
                <th>Organization</th>
                <th>Status</th>
                <th>Approved At</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% requests.forEach(request => { %>
                <tr>
                  <td><%= request.requesterUsername %></td>
                  <td><%= request.commonName %></td>
                  <td><%= request.organization %></td>
                  <td class="cell-center">
                    <span class="badge <%= request.status.toLowerCase() %>">
                      <%= request.status %>
                    </span>
                  </td>
                  <td>
                    <%= request.approvedAt ? new Date(request.approvedAt).toLocaleString() : "-" %>
                  </td>
                  <td class="cell-start">
                    <a href="/pending/<%= request._id %>" class="view-btn">View Details</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <a href="/dashboard" class="back-btn">Back to Dashboard</a>
    </div>
  </div>
</body>
</html>
