<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Request Certificate Form</title>
  <link rel="stylesheet" href="/styles.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/forge/1.3.1/forge.min.js"></script>
</head>

<body>
  <div class="page-shell narrow">
    <div class="card">
      <div class="page-header centered">
        <h2 class="page-heading">Request Certificate</h2>
      </div>

      <% if (error) { %>
        <div class="message-box error-box">
          <%= error %>
        </div>
        <% } %>

          <% if (success) { %>
            <div class="message-box success-box">
              <%= success %>
            </div>
            <% } %>

              <div id="csr-status" class="message-box csr-status-box" style="display:none;"></div>

              <form id="cert-form">
                <div class="form-grid">
                  <div>
                    <label for="commonName">Common Name (CN)</label>
                    <input id="commonName" type="text" placeholder="e.g. test.example.com" required />
                  </div>

                  <div>
                    <label for="organization">Organization (O)</label>
                    <input id="organization" type="text" required />
                  </div>

                  <div>
                    <label for="organizationalUnit">Organizational Unit (OU)</label>
                    <input id="organizationalUnit" type="text" required />
                  </div>

                  <div>
                    <label for="country">Country (C)</label>
                    <input id="country" type="text" maxlength="2" placeholder="e.g. US" required />
                  </div>

                  <div>
                    <label for="email">Email</label>
                    <input id="email" type="email" required />
                  </div>
                </div>

                <div class="form-actions">
                  <button type="submit" id="submit-btn">Submit</button>
                  <a href="/dashboard" class="back-link">Back</a>
                </div>
              </form>
    </div>
  </div>

  <script>
    const form = document.getElementById('cert-form');
    const submitBtn = document.getElementById('submit-btn');
    const statusBox = document.getElementById('csr-status');

    function showStatus(msg, type) {
      statusBox.textContent = msg;
      statusBox.className = 'message-box csr-status-box ' + (type || 'info-box');
      statusBox.style.display = 'block';
    }

    function resetBtn() {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit';
    }

    // Generates RSA-2048 key pair + PKCS#10 CSR entirely in the browser.
    function generateCsrPem({ commonName, organization, organizationalUnit, country, email }) {
      return new Promise((resolve, reject) => {
        setTimeout(() => {
          try {
            const keyPair = forge.pki.rsa.generateKeyPair({ bits: 2048, e: 0x10001 });

            const csr = forge.pki.createCertificationRequest();
            csr.publicKey = keyPair.publicKey;
            csr.setSubject([
              { name: 'countryName', value: country },
              { name: 'organizationName', value: organization },
              { name: 'organizationalUnitName', value: organizationalUnit },
              { name: 'commonName', value: commonName },
              { name: 'emailAddress', value: email },
            ]);

            csr.sign(keyPair.privateKey, forge.md.sha256.create());

            resolve(forge.pki.certificationRequestToPem(csr));
          } catch (err) {
            reject(err);
          }
        }, 0);
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const commonName = document.getElementById('commonName').value.trim();
      const organization = document.getElementById('organization').value.trim();
      const organizationalUnit = document.getElementById('organizationalUnit').value.trim();
      const country = document.getElementById('country').value.trim().toUpperCase();
      const email = document.getElementById('email').value.trim();

      if (!commonName || !organization || !organizationalUnit || !country || !email) {
        showStatus('All fields are required.', 'error-box');
        return;
      }

      if (country.length !== 2) {
        showStatus('Country must be a 2-letter code (e.g. US, DE, PK).', 'error-box');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Generating key…';
      showStatus('Generating your key pair. This takes a moment…', 'info-box');

      try {
        const csrPem = await generateCsrPem({
          commonName, organization, organizationalUnit, country, email,
        });

        showStatus('Submitting request…', 'info-box');

        const response = await fetch('/request', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            commonName,
            organization,
            organizationalUnit,
            country,
            email,
            csrPem,
            clientSideCsr: 'true',
          }),
        });

        const data = await response.json();

        if (data.success) {
          showStatus(data.message, 'success-box');
          form.reset();
          resetBtn();
        } else {
          showStatus(data.error || 'Submission failed. Please try again.', 'error-box');
          resetBtn();
        }

      } catch (err) {
        console.error('Error:', err);
        showStatus('Something went wrong. Please try again.', 'error-box');
        resetBtn();
      }
    });
  </script>
</body>

</html>